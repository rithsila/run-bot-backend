# Copy to `.env` next to docker-compose.yml. Compose reads it for ${VAR}
# interpolation. These are the variables the run-bot-api needs.

# Port the API listens on inside the container and on 127.0.0.1 on the host.
PORT=4000

# CORS allowlist — the SafetyScore web origin that the browser loads from.
FRONTEND_URL=https://app.safetyscore.example

# MongoDB connection string (e.g. MongoDB Atlas connection URI).
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/run-bot

# ES256 PUBLIC key that verifies SafetyScore-signed bot/browser tokens.
# Raw PEM (-----BEGIN PUBLIC KEY-----) or base64-encoded PEM, single line.
# This is the PUBLIC half only — the private key lives in SafetyScore, never here.
SAFETYSCORE_TOKEN_PUBLIC_KEY=

