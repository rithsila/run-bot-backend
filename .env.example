NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# MongoDB (the only datastore — no Redis, no BullMQ)
MONGO_URI=mongodb://127.0.0.1:27017/run-bot

# ES256 public key used to VERIFY SafetyScore-signed bot/browser tokens.
# Accepts a raw PEM (-----BEGIN PUBLIC KEY-----) or a base64-encoded PEM.
SAFETYSCORE_TOKEN_PUBLIC_KEY=
